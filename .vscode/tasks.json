{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build GBA ROM",
            "detail": "Compiles src/*.c -> game.elf -> game.gba via devkitARM",
            "type": "shell",
            "command": "C:/msys64/usr/bin/bash.exe",
            "args": [
                "-lc", "cd '${workspaceFolder}' && make"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": {
                "owner": "arm-gcc",
                "fileLocation": ["absolute"],
                "pattern": {
                    "regexp": "^(.+?):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "column": 3,
                    "severity": 4,
                    "message": 5
                }
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "clear": true
            }
        },
        {
            "label": "Run in mGBA",
            "detail": "Build the ROM then opens it in mGBA",
            "type": "shell",
            "command": "C:/msys64/usr/bin/bash.exe",
            "args": [
                "-lc", "cd '${workspaceFolder}' && make run MGBA='/c/Program Files/mGBA/mGBA.exe'"
            ],
            "group": "test",
            "dependsOn": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "Clean",
            "detail": "Removes build/, game.elf, game.gba, game.map",
            "type": "shell",
            "command": "C:/msys64/usr/bin/bash.exe",
            "args": [
                "-lc", "cd '${workspaceFolder}' && make clean"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "silent",
                "panel": "shared"
            }
        }
    ]
}